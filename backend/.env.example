DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0,[::1]
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Production (Vercel + Render): полный URL фронта со схемой, без пути и без / в конце.
# Пример: https://furnitech-calc.vercel.app
# Несколько origin — через запятую. Иначе логин с Vercel даст в браузере «Failed to fetch».
# CORS_ALLOWED_ORIGINS=https://furnitech-calc.vercel.app,http://127.0.0.1:5173
# То же для CSRF (формы админки / сессии):
# DJANGO_CSRF_TRUSTED_ORIGINS=https://furnitech-calc.vercel.app
# Либо разрешить все поддомены *.vercel.app (удобно для preview-деплоев):
# CORS_ALLOW_VERCEL=true
# Supabase Postgres (если задано — SQLite не используется):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
# Либо без URI (удобно, если в пароле спецсимволы):
# DATABASE_HOST=db.xxxx.supabase.co
# DATABASE_PORT=5432
# DATABASE_USER=postgres
# DATABASE_PASSWORD=
# DATABASE_NAME=postgres
# Пулер Supabase (порт 6543) — см. docs/DEPLOY.md:
# DATABASE_PGBOUNCER=true
# Раздавать загруженные media с диска вне DEBUG (эфемерно на Render без Persistent Disk):
# DJANGO_SERVE_MEDIA=false
