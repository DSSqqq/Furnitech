# Публичный URL бэкенда (Render), без завершающего слэша.
# Для локального `npm run dev` не задавайте VITE_API_ORIGIN (в репозитории есть `.env.development`).
# Не копируйте этот пример в `frontend/.env` без правки — иначе фронт будет бить в прод.
# В dev без URL — запросы идут через Vite proxy на localhost:8000.
# Для прод-сборки см. также .env.production (или задайте в Vercel → Environment Variables).
VITE_API_ORIGIN=https://furnitech-calc.onrender.com
